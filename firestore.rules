rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{document=**} {
      allow read, write: if true;
    }

    match /siteContent/homepage {
      allow read, write: if true;
    }

    match /users/{document=**} {
      allow read, write: if true;
    }
  }
}
